{
  "manifest_version": 3,
  "name": "DueX - Deadline Tracker",
  "version": "1.0.0",
  "description": "Clean, modern student productivity deadline tracker.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open DueX"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://courseweb.sliit.lk/*", "*://sam.sliit.lk/*", "*://*.sliit.lk/*"],
      "js": ["assets/content.js"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
